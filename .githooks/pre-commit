#!/usr/bin/env bash
# Pre-commit hook — refuses commits whose staged Python files would be
# reformatted by black.  This is the upstream-most defense against the
# "black silently rewrote my working tree but I forgot to git add" gap
# that ``make lint``'s auto-fix behaviour can otherwise mask.
#
# Pairs with the ``pre-push`` hook (which runs the full ``make lint``):
#   * pre-commit fires per commit, only on staged .py files, just runs
#     ``black --check`` — cheap, fast, blocks bad commits before they
#     even land in history.
#   * pre-push fires once per push, runs the full lint chain — catches
#     anything that slipped through (e.g. ``--no-verify`` commits, or
#     drift introduced by an editor between commit and push).
#
# Behaviour:
#   * No staged .py files                            → silent pass.
#   * black --check on staged files passes           → commit proceeds.
#   * black --check fails                            → commit blocked;
#     error tells the dev to run ``make format-python`` (which runs
#     ``black .``), ``git add`` the result, and re-commit.  Bypass with
#     ``git commit --no-verify`` in a genuine emergency, but the
#     pre-push hook + CI will both reject the same drift later.
#
# Staged-file scope is the whole repo (any ``*.py``) because the agent's
# ``make format-python`` runs ``black .`` over the entire tree, unlike
# sysmanage which scopes black to backend/ + tests/.
#
# This hook is intentionally minimal: it does NOT auto-fix and stage
# the fix, because that would silently include reformat-noise in
# commits the dev didn't intend to touch.  Explicit ``make format-python``
# + ``git add`` keeps the dev in control.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "${REPO_ROOT}" ]; then
    # Not in a working tree (shouldn't happen for pre-commit, but
    # match the pre-push hook's defensive style).  Let git handle it.
    exit 0
fi
cd "${REPO_ROOT}"

# Collect every staged .py file.  No staged Python = nothing to do.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR -- '*.py' 2>/dev/null || true)

if [ -z "${STAGED}" ]; then
    exit 0
fi

# Resolve python from the project venv if present; fall back to
# system python3 (so the hook still works for contributors who
# haven't created a venv yet — they'll see a clear ImportError if
# black isn't installed, which is the right hint).
if [ -x .venv/bin/python ]; then
    PYTHON=.venv/bin/python
elif [ -x .venv/Scripts/python.exe ]; then
    # Windows venv layout.
    PYTHON=.venv/Scripts/python.exe
else
    PYTHON=python3
fi

if ! "${PYTHON}" -m black --check ${STAGED} > /dev/null 2>&1; then
    echo ""
    echo "[pre-commit] black would reformat one or more staged Python files."
    echo "             Fix locally with:"
    echo ""
    echo "                 make format-python    # or: ${PYTHON} -m black ."
    echo "                 git add <files>"
    echo "                 git commit"
    echo ""
    echo "             Bypass with 'git commit --no-verify' if you must,"
    echo "             but pre-push and CI both run the same check and"
    echo "             will reject the drift later."
    echo ""
    exit 1
fi

exit 0

# SysManage Agent Sudoers Configuration for Ubuntu/Debian
# This file grants the sysmanage-agent user necessary privileges for system management
# File location: /etc/sudoers.d/sysmanage-agent
# Permissions: 0440 (enforced by package installer)

# Allow non-interactive sudo.
# (``Defaults:sysmanage-agent !requiretty`` used to live here but
# sudo 1.9.x removed ``requiretty`` entirely; non-interactive sudo
# is the default behavior now and the directive is rejected as an
# unknown setting on Ubuntu 26.04+, openSUSE Tumbleweed, etc.)

# Package Management (APT/DPKG)
#
# Grant the bare apt / apt-get binaries rather than scoping to
# individual subcommands.  sudo matches command arguments
# POSITIONALLY: a rule like ``/usr/bin/apt-get update`` only matches
# when ``update`` is the FIRST argument.  But the
# repository_mirroring_engine's setup_install plan runs
# ``apt-get -o Dpkg::Options::=--force-confold update`` (and the same
# ``-o`` prefix on ``install``) — the option sits before the
# subcommand, so the positional rule never matches and sudo denies
# with "user not allowed to run" / "I'm afraid I can't do that".
# Bare-binary grant matches what the engine's docstring already
# assumes ("authorizes specific binaries: apt-get, dnf, zypper, pkg")
# and the same philosophy used for sed/rm/install below — the agent's
# own code decides the argv; sudoers is the "which binary" gate.
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/apt *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/apt-get *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/dpkg -i *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/add-apt-repository *

# Snap package updates (apply_snap_updates).  ``snap refresh <name>``
# requires root to swap the system-wide snap symlinks.
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/snap refresh *
sysmanage-agent ALL=(ALL) NOPASSWD: /snap/bin/snap refresh *

# Flatpak system-installed app updates (apply_flatpak_updates).  User-
# scope flatpaks don't need sudo, but system-scope ones do; the agent
# can't always tell which scope a given bundle_id is in until it tries,
# so we authorize sudo for both call patterns.
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/flatpak update -y *

# Firmware updates via fwupd (apply_fwupd_updates).  Writes to EFI vars
# / firmware partitions, which require root.
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/fwupdmgr update *

# Distribution release upgrade (apply_ubuntu_release_updates).  Rewrites
# /etc/apt/sources.list and runs apt-get dist-upgrade under the hood.
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/do-release-upgrade *

# Repository mirroring tools (Pro+ repository_mirroring_engine).  The
# engine's sync plan invokes these directly via sudo to keep
# /var/mirror/<name>/ in sync with upstream and to refresh distro
# metadata after each sync.  Without these rules, sync runs fail at
# the apt-mirror / createrepo step with "user not allowed".
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/apt-mirror
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/createrepo_c, /usr/sbin/createrepo
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/reposync
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/trickle

# Memory containment for mirror syncs (repository_mirroring_engine).
# apt-mirror (especially the ``apt-mirror2`` Python rewrite that ships
# as ``apt-mirror`` on recent distros) parses the full upstream package
# index into RAM per worker and can OOM a small mirror host, taking the
# sysmanage-agent down with it.  The engine wraps the sync in a
# transient systemd scope (``systemd-run --scope -p MemoryMax=…``) so a
# runaway sync is contained to a cgroup OOM instead of a machine-wide
# one.  Bare-binary grant (same philosophy as the tools above); the
# engine decides the argv and skips the wrap at run time when this
# grant is absent, so older hosts simply run uncapped.
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/systemd-run, /bin/systemd-run

# Helper utilities the mirroring/snapshot/import plans run via sudo.
# mkdir creates the per-mirror tree before apt-mirror lays it out;
# find prunes partial-fetch ``.tmp`` files after a sync; chmod/chown
# fix permissions when a snapshot is read-only-frozen or restored;
# rsync copies the live mirror tree into .snapshots/<id>/ (snapshot
# action) and back out again (restore action).
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/mkdir, /bin/mkdir
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/find
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/chmod, /bin/chmod
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/chown, /bin/chown
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/rsync

# Air-gap repository ingestion (Pro+ airgap_repository_engine).  The
# repository ingestion orchestrator dispatches a loop-mount of the
# transferred ISO read-only, rsyncs the verified payload into the
# local mirror tree, then unmounts.  Bare-binary grants (same
# philosophy as the mirroring tools above): the orchestrator's own
# code decides the argv; sudoers gates which binary may run as root.
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/mount, /bin/mount
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/umount, /bin/umount

# Repository File Management.
#
# sudo 1.9.x rejects wildcard characters that appear inside command
# arguments (it accepts them only at the end of a single argument
# and not inside path components).  The earlier form of these rules
# tried to restrict ``sed -i`` and ``rm -f`` to the apt sources.list.d
# tree using ``/etc/apt/sources.list.d/*`` patterns — but that wildcard
# now causes the line to be silently rejected by sudo, so every plan
# that touches a repo file fails with "user not allowed to run".  The
# rules below grant the bare binaries.  The agent's own code restricts
# what paths it operates on; the sudoers file is the "what binaries
# can we invoke" layer, not the "what specific argv" layer.
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/sed, /usr/bin/sed
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/rm, /usr/bin/rm

# Generic file deployment via ``sudo install`` (used by repository
# mirror apply, agent config push, and any other plan that uses the
# ``generic_deployment.deploy_files`` step).  Wildcards-in-argv
# constraints have been removed for the same reason as above —
# trust the agent's own path validation rather than sudoers patterns
# that newer sudo no longer accepts.
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/install

# Systemd Service Management
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/systemctl start *
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/systemctl stop *
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/systemctl restart *
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/systemctl enable *
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/systemctl disable *
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/systemctl is-active *
sysmanage-agent ALL=(ALL) NOPASSWD: /bin/systemctl daemon-reload

# Firewall Management (UFW)
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/sbin/ufw allow *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/sbin/ufw --force enable
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/sbin/ufw disable
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/sbin/ufw reload
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/sbin/ufw status *

# Firewall Management (firewalld - if installed)
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/firewall-cmd *

# Ubuntu Pro Management
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/pro attach *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/pro detach *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/pro enable *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/pro disable *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/pro status *

# System Power Management
sysmanage-agent ALL=(ALL) NOPASSWD: /sbin/shutdown -r *
sysmanage-agent ALL=(ALL) NOPASSWD: /sbin/shutdown -h *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/sbin/shutdown -r *
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/sbin/shutdown -h *

# Certificate Management
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/sbin/update-ca-certificates
sysmanage-agent ALL=(ALL) NOPASSWD: /usr/bin/update-ca-trust extract

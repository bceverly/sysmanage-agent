# SysManage Agent Sudoers Configuration for NetBSD
# This file grants the sysmanage user necessary privileges for system management
# File location: /usr/pkg/etc/sudoers.d/sysmanage-agent
# Permissions: 0440 (enforced by package installer)
#
# The agent runs as the ``sysmanage`` user when ``sysmanage_agent_user``
# is set in /etc/rc.conf — see installer/netbsd/sysmanage_agent.rc.
# When the operator runs the agent as root no sudo is needed.

# Package Management (pkgin / pkg_add).
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/pkgin update
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/pkgin install *
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/pkgin remove *
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/pkgin upgrade *
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/pkgin full-upgrade
sysmanage ALL=(ALL) NOPASSWD: /usr/sbin/pkg_add *
sysmanage ALL=(ALL) NOPASSWD: /usr/sbin/pkg_delete *

# Repository mirroring tools (Pro+ repository_mirroring_engine).
# rsync is the snapshot + restore workhorse — without it, ``snapshot``
# plans fail at the live-tree -> .snapshots/<id>/ copy with the
# "user not allowed to run" error.
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/rsync

# Air-gap collector ISO build (Pro+ airgap_collector_engine): build_iso_plan
# bundles the staging tree with ``sudo xorriso`` and checksums it with
# ``sudo sha256sum``.  Bare-binary grants; without them the run dies at
# BUILDING_ISO with a sudo password prompt.  NOTE: NetBSD base has no
# ``sha256sum``; a NetBSD collector needs the pkgsrc ``coreutils`` pkg,
# which installs /usr/pkg/bin/sha256sum (and xorriso via the xorriso pkg).
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/xorriso
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/sha256sum
# Optical-disc burn (build_iso_plan with a burn_device): ``sudo
# growisofs`` writes the ISO, ``sudo eject`` (pkgsrc sysutils/eject)
# ejects it.  CVE/compliance snapshot fetch uses ``sudo curl``.
# Repository ingestion loop-mounts media read-only.
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/growisofs
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/eject
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/curl
sysmanage ALL=(ALL) NOPASSWD: /sbin/mount
sysmanage ALL=(ALL) NOPASSWD: /sbin/umount
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/createrepo_c
sysmanage ALL=(ALL) NOPASSWD: /usr/pkg/bin/trickle

# Helper utilities the mirroring/snapshot/import plans run via sudo.
sysmanage ALL=(ALL) NOPASSWD: /bin/mkdir
sysmanage ALL=(ALL) NOPASSWD: /usr/bin/find
sysmanage ALL=(ALL) NOPASSWD: /bin/chmod
sysmanage ALL=(ALL) NOPASSWD: /usr/sbin/chown
sysmanage ALL=(ALL) NOPASSWD: /usr/bin/sed
sysmanage ALL=(ALL) NOPASSWD: /bin/rm

# Generic file deployment via ``sudo install``.
sysmanage ALL=(ALL) NOPASSWD: /usr/bin/install

# Service Management (rc.d).
sysmanage ALL=(ALL) NOPASSWD: /etc/rc.d/* start
sysmanage ALL=(ALL) NOPASSWD: /etc/rc.d/* stop
sysmanage ALL=(ALL) NOPASSWD: /etc/rc.d/* restart
sysmanage ALL=(ALL) NOPASSWD: /etc/rc.d/* status

# Firewall Management (npf / pf).
sysmanage ALL=(ALL) NOPASSWD: /usr/sbin/npfctl *
sysmanage ALL=(ALL) NOPASSWD: /sbin/pfctl *

# System Power Management.
sysmanage ALL=(ALL) NOPASSWD: /sbin/shutdown -r *
sysmanage ALL=(ALL) NOPASSWD: /sbin/shutdown -h *
sysmanage ALL=(ALL) NOPASSWD: /sbin/shutdown -p *
sysmanage ALL=(ALL) NOPASSWD: /sbin/reboot
sysmanage ALL=(ALL) NOPASSWD: /sbin/poweroff
